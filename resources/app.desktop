[Desktop Entry]
Name=System Monitor
Comment=A system monitor applet for the COSMIC desktop
Type=Application
Icon=com.github.bgub.CosmicExtAppletSysmon
Exec=cosmic-ext-applet-sysmon %F
Terminal=false
StartupNotify=true
Categories=COSMIC
Keywords=COSMIC;system;monitor;cpu;ram;network;disk;gpu
NoDisplay=true
X-CosmicApplet=true
X-CosmicHoverPopup=Auto
MimeType=
